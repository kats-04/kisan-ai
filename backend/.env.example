# KrishiMitra Backend Environment Variables
# Copy this file to .env and fill in your values

# App Settings
APP_NAME=KrishiMitra API
APP_VERSION=1.0.0
DEBUG=false
ENVIRONMENT=production

# Server
HOST=0.0.0.0
PORT=8000

# MongoDB (use MongoDB Atlas free tier for production)
MONGODB_URL=mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=krishimitra

# JWT Security (generate a strong random key)
JWT_SECRET_KEY=your-super-secret-jwt-key-minimum-32-characters-long
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=10080

# AI Providers (use at least one)
# Get free API key from: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# Get free API key from: https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# Get free API key from: https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=your_huggingface_api_key_here

# Default AI provider (gemini | groq | huggingface)
DEFAULT_AI_PROVIDER=gemini

# Weather API (free tier at: https://openweathermap.org/api)
OPENWEATHER_API_KEY=your_openweather_api_key_here

# CORS - Add your frontend URL
ALLOWED_ORIGINS=http://localhost:3000,https://your-app.netlify.app

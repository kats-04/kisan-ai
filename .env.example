# KrishiMitra environment template
# Copy the values you need into:
#   - backend/.env
#   - frontend/.env.local
#
# Keep this file in the repository as the single source of truth for setup.

# Backend settings
APP_NAME=KrishiMitra API
APP_VERSION=1.0.0
DEBUG=false
ENVIRONMENT=development

HOST=0.0.0.0
PORT=8000

MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=krishimitra

JWT_SECRET_KEY=change-me-to-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=10080

GEMINI_API_KEY=
GROQ_API_KEY=
HUGGINGFACE_API_KEY=
DEFAULT_AI_PROVIDER=gemini

OPENWEATHER_API_KEY=

ALLOWED_ORIGINS=http://localhost:3000,https://your-app.netlify.app

# Frontend settings
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=KrishiMitra
